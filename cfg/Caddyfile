# Shunt — Caddy reverse proxy configuration
# SPDX-License-Identifier: AGPL-3.0-only
#
# Blue-green load balancing with active health checking.
# Caddy probes /healthz on each upstream every 10s and routes
# around unhealthy instances automatically.

:80 {
	reverse_proxy shunt-blue:8080 shunt-green:8080 {
		health_uri     /healthz
		health_interval 10s
		health_timeout  3s
	}

	log {
		output stdout
		format json
	}
}
