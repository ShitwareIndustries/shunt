# Shunt — Development environment variables
# Copy to dev.env and fill in values. dev.env is gitignored.

# Path to TOML config file (optional — defaults to built-in values)
LB_CONFIG=/etc/shunt/config.toml

# Override listen address (default: 0.0.0.0:8080)
LB_LISTEN_ADDR=0.0.0.0:8080

# Health check interval in milliseconds
LB_HEALTH_CHECK_INTERVAL=2000

# Logging
LB_LOG_LEVEL=debug
LB_LOG_FORMAT=json
LB_LOG_OUTPUT=stdout

# Request queue
LB_MAX_BUFFERED_REQUESTS=64
LB_BUFFERED_REQUEST_TIMEOUT=30000
